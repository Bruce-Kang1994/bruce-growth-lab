---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { categoryMap } from '../../lib/utils';

const posts = (await getCollection('posts'))
  .filter((post) => post.data.category === 'notes' && !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const cat = categoryMap['notes'];
---

<BaseLayout title={cat.label} description={cat.description}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-3">{cat.label}</h1>
      <p class="text-lg text-[var(--color-text-secondary)]">{cat.description}</p>
    </header>
    <div class="grid gap-4 sm:grid-cols-2">
      {posts.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          tags={post.data.tags}
          date={post.data.date}
          slug={post.id}
          body={post.body || ''}
        />
      ))}
    </div>
    {posts.length === 0 && <p class="text-[var(--color-text-secondary)]">暂无文章。</p>}
  </div>
</BaseLayout>
