---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { translations } from '../../lib/i18n';

const posts = (await getCollection('posts'))
  .filter((p) => p.data.category === 'dialogues' && !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const cat = translations.zh.category.dialogues;
---

<BaseLayout title={cat.label} description={cat.desc}>
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-12 sm:py-16">
    <header class="mb-10 animate-fade-in">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-3" data-i18n="category.dialogues.label">{cat.label}</h1>
      <p class="text-lg text-[rgb(var(--text-secondary))]" data-i18n="category.dialogues.desc">{cat.desc}</p>
    </header>
    <div class="grid gap-4 sm:grid-cols-2">
      {posts.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          tags={post.data.tags}
          date={post.data.date}
          slug={post.id}
          body={post.body || ''}
        />
      ))}
    </div>
    {posts.length === 0 && <p class="text-[rgb(var(--text-secondary))]" data-i18n="common.noArticles">暂无文章</p>}
  </div>
</BaseLayout>
