---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { categoryMap } from '../lib/utils';

const allPosts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPosts = allPosts.filter((post) => post.data.featured);
const recentPosts = allPosts.slice(0, 8);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="首页" description="Bruce 的增长方法论实验室 — 可复用的增长框架、真实案例拆解、实战经验沉淀">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 sm:pt-24 pb-12 sm:pb-16">
    <div class="max-w-2xl">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight leading-[1.15] mb-6">
        增长不靠灵感，<br />
        <span class="text-[var(--color-accent)]">靠方法论。</span>
      </h1>
      <p class="text-lg sm:text-xl text-[var(--color-text-secondary)] leading-relaxed">
        从维度分析到增长杠杆，从竞品拆解到实验闭环。<br class="hidden sm:block" />
        把增长经验变成可复用的框架，在这里沉淀和分享。
      </p>
    </div>
  </section>

  <!-- Featured -->
  {featuredPosts.length > 0 && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-12">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-secondary)] mb-5">精选文章</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {featuredPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            tags={post.data.tags}
            date={post.data.date}
            slug={post.id}
            body={post.body || ''}
            featured={true}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Recent posts -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-16">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-secondary)] mb-5">最新文章</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {recentPosts.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          tags={post.data.tags}
          date={post.data.date}
          slug={post.id}
          body={post.body || ''}
        />
      ))}
    </div>
  </section>

  <!-- Categories -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pb-20">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-[var(--color-text-secondary)] mb-5">探索分类</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {Object.entries(categoryMap).map(([key, val]) => (
        <a href={`${base}${key}/`} class="group p-5 rounded-xl border border-[var(--color-border)] hover:border-[var(--color-accent)]/40 hover:bg-[var(--color-surface-dim)] transition-all text-center">
          <div class="font-semibold text-sm mb-1">{val.label}</div>
          <div class="text-xs text-[var(--color-text-secondary)]">{val.description}</div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
