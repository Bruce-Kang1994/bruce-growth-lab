---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../lib/utils';
import { translations } from '../lib/i18n';

const allPosts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPosts = allPosts.filter((p) => p.data.featured);
const recentPosts = allPosts.filter((p) => !p.data.featured);
const base = import.meta.env.BASE_URL;
const url = (path: string) => withBase(path, base);
const cats = translations.zh.category;
---

<BaseLayout title="首页">
  <div class="max-w-[1080px] mx-auto px-6">

    <!-- Hero — compact, editorial -->
    <section class="pt-16 sm:pt-20 pb-12 sm:pb-14 border-b border-[rgb(var(--border))]">
      <h1 class="text-[28px] sm:text-[36px] font-extrabold tracking-[-0.025em] leading-[1.2] text-[rgb(var(--text-1))]" data-i18n="hero.line1">
        增长不靠灵感，靠方法论。
      </h1>
      <p class="mt-3 text-[15px] sm:text-[16px] text-[rgb(var(--text-2))] leading-relaxed max-w-[540px]" data-i18n="hero.desc">
        从维度分析到增长杠杆，从竞品拆解到实验闭环。把增长经验变成可复用的框架，在这里沉淀和分享。
      </p>
    </section>

    <!-- Categories — inline pills -->
    <section class="flex items-center gap-2 py-4 border-b border-[rgb(var(--border))] overflow-x-auto">
      {Object.entries(cats).map(([key, val]) => (
        <a href={url(`${key}/`)}
          class="shrink-0 px-3 py-1.5 text-[13px] font-medium text-[rgb(var(--text-2))] rounded-full border border-[rgb(var(--border))] hover:border-[rgb(var(--text-3))] hover:text-[rgb(var(--text-1))] transition-colors"
          data-i18n={`category.${key}.label`}>
          {val.label}
        </a>
      ))}
    </section>

    <!-- Featured -->
    {featuredPosts.length > 0 && (
      <section class="pt-8">
        <h2 class="section-label" data-i18n="home.featured">精选</h2>
        <div>
          {featuredPosts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              tags={post.data.tags}
              date={post.data.date}
              slug={post.id}
              body={post.body || ''}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Latest -->
    <section class="pt-8 pb-16">
      <h2 class="section-label" data-i18n="home.latest">最新</h2>
      <div>
        {recentPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            tags={post.data.tags}
            date={post.data.date}
            slug={post.id}
            body={post.body || ''}
          />
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .section-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgb(var(--text-3));
    margin-bottom: 4px;
  }
</style>
