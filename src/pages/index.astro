---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { categoryColors, withBase } from '../lib/utils';
import { translations } from '../lib/i18n';

const allPosts = (await getCollection('posts'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredPosts = allPosts.filter((p) => p.data.featured);
const recentPosts = allPosts.slice(0, 8);
const base = import.meta.env.BASE_URL;
const url = (path: string) => withBase(path, base);
const cats = translations.zh.category;
---

<BaseLayout title="首页">
  <!-- Hero -->
  <section class="hero-gradient">
    <div class="max-w-6xl mx-auto px-5 sm:px-8 pt-20 sm:pt-28 pb-16 sm:pb-20">
      <div class="max-w-2xl animate-fade-in">
        <h1 class="text-4xl sm:text-[3.25rem] font-extrabold tracking-tight leading-[1.12] mb-6">
          <span data-i18n="home.heroTitle1">增长不靠灵感，</span><br />
          <span class="gradient-text" data-i18n="home.heroTitle2">靠方法论。</span>
        </h1>
        <p class="text-lg sm:text-xl text-[rgb(var(--text-secondary))] leading-relaxed max-w-xl" data-i18n="home.heroDesc">
          从维度分析到增长杠杆，从竞品拆解到实验闭环。把增长经验变成可复用的框架。
        </p>
      </div>
    </div>
  </section>

  <!-- Featured -->
  {featuredPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-5 sm:px-8 pb-12 -mt-2">
      <h2 class="section-title" data-i18n="home.featured">精选文章</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {featuredPosts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            category={post.data.category}
            tags={post.data.tags}
            date={post.data.date}
            slug={post.id}
            body={post.body || ''}
            featured={true}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Latest -->
  <section class="max-w-6xl mx-auto px-5 sm:px-8 pb-16">
    <h2 class="section-title" data-i18n="home.latest">最新文章</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {recentPosts.map((post) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          tags={post.data.tags}
          date={post.data.date}
          slug={post.id}
          body={post.body || ''}
        />
      ))}
    </div>
  </section>

  <!-- Categories -->
  <section class="max-w-6xl mx-auto px-5 sm:px-8 pb-24">
    <h2 class="section-title" data-i18n="home.explore">探索分类</h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {Object.entries(cats).map(([key, val]) => {
        const c = categoryColors[key];
        return (
          <a href={url(`${key}/`)} class="card group p-6 text-center">
            <div class:list={["inline-flex w-10 h-10 rounded-xl items-center justify-center text-sm font-mono font-bold mb-3", c.bg, c.text]}>
              {c.icon}
            </div>
            <div class="font-semibold text-[15px] mb-1 group-hover:text-[rgb(var(--accent))] transition-colors" data-i18n={`category.${key}.label`}>
              {val.label}
            </div>
            <div class="text-xs text-[rgb(var(--text-tertiary))] leading-relaxed" data-i18n={`category.${key}.desc`}>
              {val.desc}
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <style>
    .section-title {
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgb(var(--text-tertiary));
      margin-bottom: 1.25rem;
    }
  </style>
</BaseLayout>
