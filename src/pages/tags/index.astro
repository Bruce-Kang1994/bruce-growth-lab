---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../../lib/utils';

const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
const tagCounts = new Map<string, number>();
allPosts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="标签" description="按标签浏览所有文章">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-8">标签</h1>
    <div class="flex flex-wrap gap-3">
      {sortedTags.map(([tag, count]) => (
        <a
          href={`${base}tags/${slugify(tag)}/`}
          class="px-4 py-2 rounded-full border border-[var(--color-border)] text-sm hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 transition-all"
        >
          #{tag}
          <span class="ml-1 text-[var(--color-text-secondary)]">({count})</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
