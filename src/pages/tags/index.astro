---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { slugify, withBase } from '../../lib/utils';

const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
const tagCounts = new Map<string, number>();
allPosts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const sortedTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
const base = import.meta.env.BASE_URL;
const url = (path: string) => withBase(path, base);
---

<BaseLayout title="标签" description="按标签浏览所有文章">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-12 sm:py-16">
    <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-8 animate-fade-in" data-i18n="tags.title">标签</h1>
    <div class="flex flex-wrap gap-3 animate-fade-in" style="animation-delay: 0.1s">
      {sortedTags.map(([tag, count]) => (
        <a
          href={url(`tags/${slugify(tag)}/`)}
          class="px-4 py-2.5 rounded-xl border border-[rgb(var(--border))] text-sm font-medium hover:border-[rgb(var(--accent))] hover:text-[rgb(var(--accent))] hover:bg-[rgb(var(--accent))]/5 transition-all"
        >
          #{tag}
          <span class="ml-1.5 text-[rgb(var(--text-tertiary))]">({count})</span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
