---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../../lib/utils';

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
  const tagSet = new Set<string>();
  allPosts.forEach((post) => post.data.tags.forEach((tag) => tagSet.add(tag)));

  return [...tagSet].map((tag) => ({
    params: { tag: slugify(tag) },
    props: {
      tag,
      posts: allPosts
        .filter((post) => post.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`标签 "${tag}" 下的所有文章`}>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight">
        <span class="text-[var(--color-accent)]">#</span>{tag}
      </h1>
      <p class="mt-2 text-[var(--color-text-secondary)]">共 {posts.length} 篇文章</p>
    </header>
    <div class="grid gap-4 sm:grid-cols-2">
      {posts.map((post: any) => (
        <ArticleCard
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          tags={post.data.tags}
          date={post.data.date}
          slug={post.id}
          body={post.body || ''}
        />
      ))}
    </div>
  </div>
</BaseLayout>
