---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { slugify } from '../../lib/utils';

export async function getStaticPaths() {
  const allPosts = (await getCollection('posts')).filter((p) => !p.data.draft);
  const tagSet = new Set<string>();
  allPosts.forEach((p) => p.data.tags.forEach((t) => tagSet.add(t)));
  return [...tagSet].map((tag) => ({
    params: { tag: slugify(tag) },
    props: {
      tag,
      posts: allPosts.filter((p) => p.data.tags.includes(tag)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`#${tag}`}>
  <div class="max-w-[1080px] mx-auto px-6 py-12 sm:py-16">
    <header class="mb-6 pb-6 border-b border-[rgb(var(--border))]">
      <h1 class="text-[24px] sm:text-[28px] font-extrabold tracking-[-0.02em]">
        <span class="text-[rgb(var(--accent))]">#</span>{tag}
      </h1>
      <p class="mt-1 text-[14px] text-[rgb(var(--text-3))]">{posts.length} <span data-i18n="tags.articles">篇文章</span></p>
    </header>
    <div>
      {posts.map((post: any) => (
        <ArticleCard title={post.data.title} description={post.data.description} category={post.data.category}
          tags={post.data.tags} date={post.data.date} slug={post.id} body={post.body || ''} />
      ))}
    </div>
  </div>
</BaseLayout>
