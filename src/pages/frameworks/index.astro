---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { translations } from '../../lib/i18n';

const posts = (await getCollection('posts'))
  .filter((p) => p.data.category === 'frameworks' && !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const cat = translations.zh.category.frameworks;
---

<BaseLayout title={cat.label} description={cat.desc}>
  <div class="max-w-[1080px] mx-auto px-6 py-12 sm:py-16">
    <header class="mb-6 pb-6 border-b border-[rgb(var(--border))]">
      <h1 class="text-[24px] sm:text-[28px] font-extrabold tracking-[-0.02em]" data-i18n="category.frameworks.label">{cat.label}</h1>
      <p class="mt-1.5 text-[14px] text-[rgb(var(--text-2))]" data-i18n="category.frameworks.desc">{cat.desc}</p>
    </header>
    <div>
      {posts.map((post) => (
        <ArticleCard title={post.data.title} description={post.data.description} category={post.data.category}
          tags={post.data.tags} date={post.data.date} slug={post.id} body={post.body || ''} />
      ))}
    </div>
    {posts.length === 0 && <p class="text-[rgb(var(--text-3))] py-8" data-i18n="common.noArticles">暂无文章</p>}
  </div>
</BaseLayout>
