---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';
import { formatDate, readingTime, slugify, withBase } from '../lib/utils';
import { translations } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  date: Date;
  headings: { depth: number; slug: string; text: string }[];
  body: string;
  relatedPosts?: { title: string; slug: string; category: string }[];
}

const { title, description, category, tags, date, headings, body, relatedPosts = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
const url = (path: string) => withBase(path, base);
const catLabel = translations.zh.category[category as keyof typeof translations.zh.category]?.label || category;
const mins = readingTime(body);
---

<BaseLayout title={title} description={description}>
  <div class="max-w-[1080px] mx-auto px-6 py-10 sm:py-16">
    <!-- Header -->
    <header class="max-w-[720px] mb-10">
      <div class="flex items-center gap-2 mb-4 text-[13px] text-[rgb(var(--text-3))]">
        <a href={url(`${category}/`)} class="font-medium text-[rgb(var(--text-2))] hover:text-[rgb(var(--accent))] transition-colors" data-i18n={`category.${category}.label`}>
          {catLabel}
        </a>
        <span>&middot;</span>
        <span>{formatDate(date)}</span>
        <span>&middot;</span>
        <span>{mins} min</span>
      </div>

      <h1 class="text-[28px] sm:text-[32px] font-extrabold leading-[1.25] tracking-[-0.02em] mb-4">
        {title}
      </h1>

      <p class="text-[15px] text-[rgb(var(--text-2))] leading-relaxed">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-5">
          {tags.map((tag) => (
            <a href={url(`tags/${slugify(tag)}/`)}
              class="text-[12px] px-2.5 py-1 rounded-full border border-[rgb(var(--border))] text-[rgb(var(--text-3))] hover:text-[rgb(var(--accent))] hover:border-[rgb(var(--accent))]/40 transition-colors">
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- Content + TOC -->
    <div class="flex gap-16">
      <article class="prose flex-1 min-w-0">
        <slot />
      </article>
      <TOC headings={headings} />
    </div>

    <!-- Related -->
    {relatedPosts.length > 0 && (
      <section class="max-w-[720px] mt-16 pt-8 border-t border-[rgb(var(--border))]">
        <h3 class="text-[13px] font-semibold uppercase tracking-wide text-[rgb(var(--text-3))] mb-4" data-i18n="article.related">相关文章</h3>
        <div class="space-y-0">
          {relatedPosts.map((post) => {
            const rl = translations.zh.category[post.category as keyof typeof translations.zh.category]?.label;
            return (
              <a href={url(`posts/${post.slug}/`)} class="group flex items-center justify-between py-3 border-b border-[rgb(var(--border))] last:border-b-0">
                <div>
                  <span class="text-[12px] text-[rgb(var(--text-3))]" data-i18n={`category.${post.category}.label`}>{rl}</span>
                  <h4 class="text-[15px] font-medium group-hover:text-[rgb(var(--accent))] transition-colors">{post.title}</h4>
                </div>
                <svg class="w-4 h-4 shrink-0 text-[rgb(var(--text-3))] opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"/></svg>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
