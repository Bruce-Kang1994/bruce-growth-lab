---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';
import { formatDate, readingTime, categoryColors, slugify, withBase } from '../lib/utils';
import { translations } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  date: Date;
  headings: { depth: number; slug: string; text: string }[];
  body: string;
  relatedPosts?: { title: string; slug: string; category: string }[];
}

const { title, description, category, tags, date, headings, body, relatedPosts = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
const url = (path: string) => withBase(path, base);
const colors = categoryColors[category] || categoryColors.frameworks;
const catLabel = translations.zh.category[category as keyof typeof translations.zh.category]?.label || category;
const mins = readingTime(body);
---

<BaseLayout title={title} description={description}>
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-10 sm:py-16">
    <!-- Article header -->
    <header class="max-w-[720px] mb-12 animate-fade-in">
      <div class="flex items-center gap-3 mb-5">
        <a href={url(`${category}/`)}
          class:list={["inline-flex px-3 py-1.5 rounded-lg text-xs font-semibold transition-opacity hover:opacity-80", colors.bg, colors.text]}
          data-i18n={`category.${category}.label`}>
          {catLabel}
        </a>
        <span class="text-sm text-[rgb(var(--text-tertiary))]">{formatDate(date)}</span>
        <span class="text-sm text-[rgb(var(--text-tertiary))]">&middot; {mins} min</span>
      </div>

      <h1 class="text-3xl sm:text-[2.5rem] font-extrabold leading-[1.2] tracking-tight mb-5">
        {title}
      </h1>

      <p class="text-lg text-[rgb(var(--text-secondary))] leading-relaxed">
        {description}
      </p>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-6">
          {tags.map((tag) => (
            <a href={url(`tags/${slugify(tag)}/`)}
              class="text-sm px-3 py-1 rounded-lg border border-[rgb(var(--border))] text-[rgb(var(--text-secondary))] hover:border-[rgb(var(--accent))] hover:text-[rgb(var(--accent))] transition-all">
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- Content + TOC -->
    <div class="flex gap-16">
      <article class="prose flex-1 min-w-0 animate-fade-in" style="animation-delay: 0.1s">
        <slot />
      </article>
      <TOC headings={headings} />
    </div>

    <!-- Related posts -->
    {relatedPosts.length > 0 && (
      <section class="max-w-[720px] mt-20 pt-10 border-t border-[rgb(var(--border))]">
        <h3 class="text-lg font-bold mb-5" data-i18n="article.related">相关文章</h3>
        <div class="space-y-3">
          {relatedPosts.map((post) => {
            const rc = categoryColors[post.category] || categoryColors.frameworks;
            const rl = translations.zh.category[post.category as keyof typeof translations.zh.category]?.label;
            return (
              <a href={url(`posts/${post.slug}/`)} class="card block p-4">
                <span class:list={["text-xs font-semibold", rc.text]} data-i18n={`category.${post.category}.label`}>{rl}</span>
                <h4 class="font-medium mt-1 group-hover:text-[rgb(var(--accent))]">{post.title}</h4>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
