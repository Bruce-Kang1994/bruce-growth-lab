---
import '../styles/global.css';
import { withBase } from '../lib/utils';
import { translations } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Bruce 的增长方法论实验室" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
const url = (path: string) => withBase(path, base);
const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const isActive = (path: string) => {
  const target = url(path);
  if (target === url('')) return currentPath === target;
  return currentPath === target || currentPath.startsWith(target);
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Bruce's Growth Lab</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={`${title} | Bruce's Growth Lab`} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" type="image/svg+xml" href={url('favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script is:inline>
      const t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme:dark)').matches)) document.documentElement.classList.add('dark');
    </script>
  </head>
  <body class="min-h-screen flex flex-col page-shell">

    <!-- Header -->
    <header class="sticky top-0 z-50 border-b border-[rgb(var(--border))] bg-[rgb(var(--surface-0))]/88 backdrop-blur-md">
      <div class="max-w-[1160px] mx-auto px-6">
        <div class="h-16 flex items-center justify-between gap-4">
          <a href={url('')} class="min-w-0 group">
            <div class="text-[11px] uppercase tracking-[0.14em] text-[rgb(var(--text-3))] mb-0.5">Bruce Kang</div>
            <div class="font-semibold text-[15px] tracking-[-0.02em] text-[rgb(var(--text-1))] group-hover:text-[rgb(var(--accent))] transition-colors">
              Growth Lab
            </div>
          </a>

          <div class="flex items-center gap-1">
            <!-- Desktop nav -->
            <nav class="hidden md:flex items-center mr-1">
              <a href={url('frameworks/')} class:list={['nav-item', isActive('frameworks/') && 'is-active']} data-i18n="nav.frameworks">框架</a>
              <a href={url('case-studies/')} class:list={['nav-item', isActive('case-studies/') && 'is-active']} data-i18n="nav.caseStudies">案例</a>
              <a href={url('dialogues/')} class:list={['nav-item', isActive('dialogues/') && 'is-active']} data-i18n="nav.dialogues">对话</a>
              <a href={url('notes/')} class:list={['nav-item', isActive('notes/') && 'is-active']} data-i18n="nav.notes">笔记</a>
              <a href={url('about/')} class:list={['nav-item', isActive('about/') && 'is-active']} data-i18n="nav.about">关于</a>
            </nav>

            <div class="flex items-center border-l border-[rgb(var(--border))] pl-2 ml-1">
              <div class="locale-switch mr-1" role="group" aria-label="Language">
                <button type="button" class="locale-btn" data-set-locale="zh" aria-pressed="true">中</button>
                <button type="button" class="locale-btn" data-set-locale="en" aria-pressed="false">EN</button>
              </div>
              <!-- Theme -->
              <button id="theme-toggle" class="ctrl-btn" aria-label="主题">
              <svg class="w-4 h-4 dark:hidden" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
              <svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2m10-10h-2M4 12H2m15.364 6.364l-1.414-1.414M7.05 7.05L5.636 5.636m12.728 0l-1.414 1.414M7.05 16.95l-1.414 1.414"/></svg>
              </button>
              <!-- Mobile -->
              <button id="menu-toggle" class="ctrl-btn md:hidden" aria-label="菜单">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile nav -->
      <nav id="mobile-menu" class="hidden md:hidden border-t border-[rgb(var(--border))] bg-[rgb(var(--surface-0))]">
        <div class="max-w-[1080px] mx-auto px-6 py-3 flex flex-col gap-0.5">
          <a href={url('frameworks/')} class="mobile-item" data-i18n="nav.frameworks">框架</a>
          <a href={url('case-studies/')} class="mobile-item" data-i18n="nav.caseStudies">案例</a>
          <a href={url('dialogues/')} class="mobile-item" data-i18n="nav.dialogues">对话</a>
          <a href={url('notes/')} class="mobile-item" data-i18n="nav.notes">笔记</a>
          <a href={url('about/')} class="mobile-item" data-i18n="nav.about">关于</a>
        </div>
      </nav>
    </header>

    <main class="flex-1"><slot /></main>

    <!-- Footer -->
    <footer class="border-t border-[rgb(var(--border))] mt-24">
      <div class="max-w-[1160px] mx-auto px-6 py-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-[30rem]">
          <div class="text-[11px] uppercase tracking-[0.14em] text-[rgb(var(--text-3))] mb-2">Growth Lab</div>
          <p class="text-[14px] leading-relaxed text-[rgb(var(--text-2))]" data-copy-zh="一个持续迭代的增长研究笔记站。只写能被迁移、拆解和复用的判断，不做信息流堆砌。" data-copy-en="An evolving growth research archive focused on judgments that can be transferred, broken down, and reused, not on publishing a content feed.">
            一个持续迭代的增长研究笔记站。只写能被迁移、拆解和复用的判断，不做信息流堆砌。
          </p>
        </div>
        <div class="text-[13px] text-[rgb(var(--text-3))] flex items-center gap-4">
          <span>&copy; {new Date().getFullYear()} Bruce's Growth Lab</span>
          <a href="https://github.com/Bruce-Kang1994" target="_blank" rel="noopener" class="hover:text-[rgb(var(--text-1))] transition-colors">GitHub</a>
        </div>
      </div>
    </footer>

    <style>
      .nav-item {
        padding: 6px 10px;
        font-size: 13px;
        font-weight: 600;
        color: rgb(var(--text-2));
        border-radius: 6px;
        letter-spacing: -0.01em;
        transition: color 0.12s, background-color 0.12s;
      }
      .nav-item:hover {
        color: rgb(var(--text-1));
        background: rgb(var(--surface-1));
      }
      .nav-item.is-active {
        color: rgb(var(--text-1));
        background: rgb(var(--surface-1));
      }
      .mobile-item {
        padding: 8px 10px;
        font-size: 14px;
        font-weight: 500;
        color: rgb(var(--text-2));
        border-radius: 6px;
      }
      .mobile-item:hover { color: rgb(var(--text-1)); background: rgb(var(--surface-1)); }
      .ctrl-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 8px;
        color: rgb(var(--text-3));
        transition: color 0.12s, background-color 0.12s;
      }
      .ctrl-btn:hover {
        color: rgb(var(--text-1));
        background: rgb(var(--surface-1));
      }
      .locale-switch {
        display: inline-flex;
        align-items: center;
        gap: 2px;
        padding: 2px;
        border-radius: 10px;
        border: 1px solid rgb(var(--border));
        background: rgb(var(--surface-1) / 0.86);
      }
      .locale-btn {
        min-width: 34px;
        height: 30px;
        padding: 0 9px;
        border-radius: 8px;
        font-size: 12px;
        font-weight: 700;
        color: rgb(var(--text-3));
        transition: color 0.12s, background-color 0.12s, box-shadow 0.12s;
      }
      .locale-btn.is-active {
        color: rgb(var(--text-1));
        background: rgb(var(--surface-0));
        box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.4);
      }
    </style>

    <script is:inline define:vars={{ i18nMessages: translations }}>
      const getNestedValue = (obj, key) => key.split('.').reduce((acc, part) => acc?.[part], obj);
      const formatLocaleDate = (value, locale) => {
        const date = new Date(value);
        if (Number.isNaN(date.valueOf())) return value;
        return locale === 'en'
          ? date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
          : date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
      };
      const applyLocale = (locale) => {
        document.documentElement.lang = locale === 'en' ? 'en' : 'zh-CN';
        document.documentElement.dataset.locale = locale;
        localStorage.setItem('locale', locale);

        document.querySelectorAll('[data-i18n]').forEach((node) => {
          const key = node.getAttribute('data-i18n');
          const value = getNestedValue(i18nMessages[locale], key);
          if (value) node.textContent = value;
        });

        document.querySelectorAll('[data-copy-zh][data-copy-en]').forEach((node) => {
          node.textContent = locale === 'en' ? node.getAttribute('data-copy-en') : node.getAttribute('data-copy-zh');
        });

        document.querySelectorAll('[data-locale-date]').forEach((node) => {
          const rawDate = node.getAttribute('data-date');
          if (rawDate) node.textContent = formatLocaleDate(rawDate, locale);
        });

        document.querySelectorAll('[data-locale-mins]').forEach((node) => {
          const mins = Number(node.getAttribute('data-mins') || '0');
          node.textContent = locale === 'en' ? `${mins} min read` : `${mins} 分钟阅读`;
        });

        document.querySelectorAll('[data-locale-count]').forEach((node) => {
          const count = Number(node.getAttribute('data-count') || '0');
          node.textContent = locale === 'en' ? `${count} posts` : `${count} 篇内容`;
        });

        document.querySelectorAll('[data-set-locale]').forEach((button) => {
          const isActive = button.getAttribute('data-set-locale') === locale;
          button.classList.toggle('is-active', isActive);
          button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      };

      const initialLocale = localStorage.getItem('locale') === 'en' ? 'en' : 'zh';
      applyLocale(initialLocale);

      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
      });
      document.getElementById('menu-toggle')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });
      document.querySelectorAll('[data-set-locale]').forEach((button) => {
        button.addEventListener('click', () => {
          const locale = button.getAttribute('data-set-locale');
          if (locale === 'zh' || locale === 'en') applyLocale(locale);
        });
      });
    </script>
  </body>
</html>
