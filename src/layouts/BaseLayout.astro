---
import '../styles/global.css';
import { withBase } from '../lib/utils';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "Bruce 的增长方法论实验室", ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
const url = (path: string) => withBase(path, base);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title} | Bruce's Growth Lab</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | Bruce's Growth Lab`} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href={url('favicon.svg')} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <!-- Dark mode init -->
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-50 border-b border-[rgb(var(--border))] bg-[rgb(var(--surface-0))]/85 backdrop-blur-lg">
      <nav class="max-w-6xl mx-auto px-5 sm:px-8 h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href={url('')} class="flex items-center gap-2.5 group">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white font-bold text-sm shadow-sm">G</div>
          <span class="font-bold text-[15px] tracking-tight group-hover:text-[rgb(var(--accent))] transition-colors">
            <span data-i18n="site.title">Bruce's Growth Lab</span>
          </span>
        </a>

        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-1">
          <a href={url('frameworks/')} class="nav-link" data-i18n="nav.frameworks">增长框架</a>
          <a href={url('case-studies/')} class="nav-link" data-i18n="nav.caseStudies">案例拆解</a>
          <a href={url('dialogues/')} class="nav-link" data-i18n="nav.dialogues">对话精华</a>
          <a href={url('notes/')} class="nav-link" data-i18n="nav.notes">学习笔记</a>
          <a href={url('about/')} class="nav-link" data-i18n="nav.about">关于</a>
        </div>

        <!-- Right controls -->
        <div class="flex items-center gap-1">
          <!-- i18n toggle -->
          <button id="lang-toggle" class="icon-btn text-xs font-semibold w-8 h-8 rounded-lg" aria-label="Switch language">
            <span id="lang-label">EN</span>
          </button>

          <!-- Theme toggle -->
          <button id="theme-toggle" class="icon-btn" aria-label="Toggle theme">
            <svg class="w-[18px] h-[18px] dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
            <svg class="w-[18px] h-[18px] hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
          </button>

          <!-- Mobile menu -->
          <button id="menu-toggle" class="icon-btn md:hidden" aria-label="Menu">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
        </div>
      </nav>

      <!-- Mobile menu panel -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-[rgb(var(--border))] bg-[rgb(var(--surface-0))]">
        <div class="px-5 py-4 space-y-1">
          <a href={url('frameworks/')} class="mobile-nav-link" data-i18n="nav.frameworks">增长框架</a>
          <a href={url('case-studies/')} class="mobile-nav-link" data-i18n="nav.caseStudies">案例拆解</a>
          <a href={url('dialogues/')} class="mobile-nav-link" data-i18n="nav.dialogues">对话精华</a>
          <a href={url('notes/')} class="mobile-nav-link" data-i18n="nav.notes">学习笔记</a>
          <a href={url('about/')} class="mobile-nav-link" data-i18n="nav.about">关于</a>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[rgb(var(--border))] mt-24">
      <div class="max-w-6xl mx-auto px-5 sm:px-8 py-10">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-md bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white font-bold text-[10px]">G</div>
            <span class="text-sm font-medium">Bruce's Growth Lab</span>
          </div>
          <p class="text-sm text-[rgb(var(--text-tertiary))]">
            &copy; {new Date().getFullYear()} &middot; <span data-i18n="footer.copyright">用方法论驱动增长</span>
          </p>
        </div>
      </div>
    </footer>

    <style>
      .nav-link {
        padding: 6px 12px;
        font-size: 14px;
        font-weight: 500;
        color: rgb(var(--text-secondary));
        border-radius: 8px;
        transition: all 0.15s ease;
      }
      .nav-link:hover {
        color: rgb(var(--text-primary));
        background: rgb(var(--surface-1));
      }
      .mobile-nav-link {
        display: block;
        padding: 10px 12px;
        font-size: 15px;
        font-weight: 500;
        color: rgb(var(--text-secondary));
        border-radius: 8px;
        transition: all 0.15s ease;
      }
      .mobile-nav-link:hover {
        color: rgb(var(--text-primary));
        background: rgb(var(--surface-1));
      }
      .icon-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        color: rgb(var(--text-secondary));
        transition: all 0.15s ease;
      }
      .icon-btn:hover {
        color: rgb(var(--text-primary));
        background: rgb(var(--surface-1));
      }
    </style>

    <script>
      // Theme toggle
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
      });

      // Mobile menu
      document.getElementById('menu-toggle')?.addEventListener('click', () => {
        document.getElementById('mobile-menu')?.classList.toggle('hidden');
      });

      // i18n
      const i18nMap: Record<string, Record<string, string>> = {
        zh: {
          'site.title': "Bruce's Growth Lab",
          'nav.frameworks': '增长框架',
          'nav.caseStudies': '案例拆解',
          'nav.dialogues': '对话精华',
          'nav.notes': '学习笔记',
          'nav.about': '关于',
          'footer.copyright': '用方法论驱动增长',
          'home.heroTitle1': '增长不靠灵感，',
          'home.heroTitle2': '靠方法论。',
          'home.heroDesc': '从维度分析到增长杠杆，从竞品拆解到实验闭环。把增长经验变成可复用的框架。',
          'home.featured': '精选文章',
          'home.latest': '最新文章',
          'home.explore': '探索分类',
          'article.toc': '目录',
          'article.related': '相关文章',
          'tags.title': '标签',
          'common.noArticles': '暂无文章',
          'category.frameworks.label': '增长框架',
          'category.frameworks.desc': '可复用的增长方法论和思维模型',
          'category.case-studies.label': '案例拆解',
          'category.case-studies.desc': '真实产品的增长策略深度分析',
          'category.dialogues.label': '对话精华',
          'category.dialogues.desc': '与增长从业者的访谈和讨论提炼',
          'category.notes.label': '学习笔记',
          'category.notes.desc': '阅读、课程和日常思考的记录',
        },
        en: {
          'site.title': "Bruce's Growth Lab",
          'nav.frameworks': 'Frameworks',
          'nav.caseStudies': 'Case Studies',
          'nav.dialogues': 'Dialogues',
          'nav.notes': 'Notes',
          'nav.about': 'About',
          'footer.copyright': 'Growth driven by methodology',
          'home.heroTitle1': 'Growth is not about inspiration,',
          'home.heroTitle2': "it's about methodology.",
          'home.heroDesc': 'From dimensional analysis to growth levers, from competitive teardowns to experiment loops.',
          'home.featured': 'Featured',
          'home.latest': 'Latest Articles',
          'home.explore': 'Explore Categories',
          'article.toc': 'Contents',
          'article.related': 'Related Articles',
          'tags.title': 'Tags',
          'common.noArticles': 'No articles yet',
          'category.frameworks.label': 'Frameworks',
          'category.frameworks.desc': 'Reusable growth methodologies and mental models',
          'category.case-studies.label': 'Case Studies',
          'category.case-studies.desc': 'Deep analysis of real product growth strategies',
          'category.dialogues.label': 'Dialogues',
          'category.dialogues.desc': 'Insights from growth practitioner conversations',
          'category.notes.label': 'Notes',
          'category.notes.desc': 'Reading notes, course takeaways, and reflections',
        },
      };

      function applyLocale(locale: string) {
        const map = i18nMap[locale] || i18nMap.zh;
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (key && map[key]) {
            el.textContent = map[key];
          }
        });
        const label = document.getElementById('lang-label');
        if (label) label.textContent = locale === 'zh' ? 'EN' : '中';
        localStorage.setItem('locale', locale);
        document.documentElement.lang = locale === 'zh' ? 'zh-CN' : 'en';
      }

      // Init locale
      const savedLocale = localStorage.getItem('locale') || 'zh';
      applyLocale(savedLocale);

      document.getElementById('lang-toggle')?.addEventListener('click', () => {
        const current = localStorage.getItem('locale') || 'zh';
        applyLocale(current === 'zh' ? 'en' : 'zh');
      });
    </script>
  </body>
</html>
