---
import { formatDate, readingTime, categoryColors, withBase } from '../lib/utils';
import { translations } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  date: Date;
  slug: string;
  body?: string;
  featured?: boolean;
}

const { title, description, category, tags, date, slug, body = '', featured = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const url = (path: string) => withBase(path, base);
const colors = categoryColors[category] || categoryColors.frameworks;
const catLabel = translations.zh.category[category as keyof typeof translations.zh.category]?.label || category;
const mins = readingTime(body);
---

<article class:list={["group", featured && "sm:col-span-2"]}>
  <a href={url(`posts/${slug}/`)} class="card block p-5 sm:p-6 h-full">
    <div class="flex items-center gap-2.5 mb-3">
      <span class:list={["inline-flex px-2.5 py-1 rounded-md text-xs font-semibold", colors.bg, colors.text]}
        data-i18n={`category.${category}.label`}>
        {catLabel}
      </span>
      <span class="text-xs text-[rgb(var(--text-tertiary))]">{formatDate(date)}</span>
      <span class="text-xs text-[rgb(var(--text-tertiary))]">&middot; {mins} min</span>
    </div>

    <h3 class:list={[
      "font-bold leading-snug tracking-tight group-hover:text-[rgb(var(--accent))] transition-colors mb-2.5",
      featured ? "text-xl sm:text-2xl" : "text-[17px]",
    ]}>
      {title}
    </h3>

    <p class="text-sm text-[rgb(var(--text-secondary))] leading-relaxed line-clamp-2 mb-3">
      {description}
    </p>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((tag) => (
          <span class="text-xs px-2 py-0.5 rounded-md bg-[rgb(var(--surface-1))] text-[rgb(var(--text-tertiary))]">
            {tag}
          </span>
        ))}
      </div>
    )}
  </a>
</article>
