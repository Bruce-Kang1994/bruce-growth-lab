---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filteredHeadings.length > 0 && (
  <nav class="hidden xl:block sticky top-24 w-56 shrink-0 self-start">
    <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-secondary)] mb-3">
      目录
    </h4>
    <ul class="space-y-1.5 text-sm border-l border-[var(--color-border)]">
      {filteredHeadings.map((h) => (
        <li>
          <a
            href={`#${h.slug}`}
            class:list={[
              "block py-0.5 text-[var(--color-text-secondary)] hover:text-[var(--color-accent)] transition-colors border-l-2 border-transparent hover:border-[var(--color-accent)] -ml-px",
              h.depth === 2 ? "pl-4" : "pl-7 text-xs",
            ]}
          >
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
